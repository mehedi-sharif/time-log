---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="theme-color" content="#1f7a6b" />
    <title>Time Log</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="description"
      content="A simple browser-based time log that stores entries locally without a database."
    />
  </head>
  <body>
    <header class="site-header">
      <div class="app-shell">
        <p class="eyebrow">Simple time tracker</p>
        <h1 id="page-title">Time Log <span id="save-status"><span class="status-dot"></span></span></h1>
      </div>
    </header>

    <main class="app-shell">
      <div class="app-layout">
        <div class="main-content">
          <section class="toolbar" aria-label="App sections">
            <div class="tabs" role="tablist" aria-label="Main sections">
              <button class="tab active" type="button" data-view="log">Log time</button>
              <button class="tab" type="button" data-view="insights">Insights</button>
              <button class="tab" type="button" data-view="goals">Goals</button>
            </div>
          </section>

          <section class="view active" id="log-view" data-panel="log" aria-label="Log time">
            <article class="panel log-panel">
              <form id="entry-form">
                <label for="activity">What did you do?</label>
                <input id="activity" name="activity" type="text" required />
                <div class="time-range">
                  <label>
                    From
                    <input id="start-time" name="start_time" type="time" required />
                  </label>
                  <span class="time-sep">→</span>
                  <label>
                    To
                    <input id="end-time" name="end_time" type="time" required />
                  </label>
                </div>
                <span class="quick-times" aria-label="Quick duration">
                  <button type="button" data-minutes="15">15m</button>
                  <button type="button" data-minutes="30" class="selected">30m</button>
                  <button type="button" data-minutes="60">1h</button>
                  <button type="button" data-minutes="90">1.5h</button>
                </span>
                <button class="primary-button" type="submit" style="margin-top: 12px;">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 5v14"></path>
                    <path d="M5 12h14"></path>
                  </svg>
                  Save Time
                </button>
              </form>
            </article>
          </section>

          <section class="view" id="insights-view" data-panel="insights" aria-label="Time insights">
            <article class="panel insight-panel">
              <div class="panel-heading">
                <h2>Where time went</h2>
                <span id="range-label">Today</span>
              </div>
              <div class="range-tabs" role="tablist" aria-label="Insight range">
                <button class="range-tab active" type="button" data-range="today">Today</button>
                <button class="range-tab" type="button" data-range="week">Week</button>
                <button class="range-tab" type="button" data-range="all">All</button>
              </div>
              <div class="stat-row">
                <div>
                  <span>Total time</span>
                  <strong id="total-time">0h 00m</strong>
                </div>
                <div>
                  <span>Top activity</span>
                  <strong id="top-activity">None</strong>
                </div>
                <div>
                  <span>Logs</span>
                  <strong id="log-count-stat">0</strong>
                </div>
              </div>
              <div class="chart" id="chart" aria-label="Activity time chart"></div>
            </article>
          </section>
          <section class="view" id="goals-view" data-panel="goals" aria-label="Goals">
            <article class="panel goals-panel">
              <div class="panel-heading">
                <h2>Goals</h2>
                <span id="goals-count">0 goals</span>
              </div>
              <form id="goal-form">
                <div class="goal-input-row">
                  <input id="goal-input" name="goal" type="text" placeholder="Add a new goal…" required />
                  <button class="primary-button" type="submit">Add</button>
                </div>
              </form>
              <div id="goals-list"></div>
            </article>
          </section>
        </div>

        <aside class="side-panel">
          <div class="today-card" aria-label="Today summary">
            <span class="today-label">Today</span>
            <strong id="today-total">0h 00m</strong>
          </div>
          <div class="entries" id="entries"></div>
        </aside>
      </div>
    </main>

    <template id="entry-template">
      <div class="entry-card">
        <div class="entry-main">
          <span class="activity-dot"></span>
          <div>
            <strong class="entry-title"></strong>
            <p class="entry-meta"></p>
            <p class="entry-notes"></p>
          </div>
        </div>
        <div class="entry-actions">
          <button class="edit-button" type="button" title="Edit entry" aria-label="Edit entry">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path>
            </svg>
          </button>
          <button class="delete-button" type="button" title="Delete entry" aria-label="Delete entry">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 6h18"></path>
              <path d="M8 6V4h8v2"></path>
              <path d="M19 6l-1 14H6L5 6"></path>
            </svg>
          </button>
        </div>
      </div>
    </template>

    <template id="goal-template">
      <div class="goal-card">
        <label class="goal-check-label">
          <input type="checkbox" class="goal-checkbox" />
          <span class="goal-title"></span>
        </label>
        <button class="delete-button goal-delete" type="button" title="Delete goal" aria-label="Delete goal">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6h18"></path>
            <path d="M8 6V4h8v2"></path>
            <path d="M19 6l-1 14H6L5 6"></path>
          </svg>
        </button>
      </div>
    </template>

    <div id="auth-gate">
      <div class="auth-box">
        <p class="eyebrow">Time Log</p>
        <h2>Enter password</h2>
        <form id="auth-form">
          <input id="auth-input" type="password" placeholder="Password" autocomplete="current-password" />
          <p id="auth-error" class="auth-error"></p>
          <button class="primary-button" type="submit">Unlock</button>
        </form>
      </div>
    </div>

    <div id="edit-modal" class="modal-backdrop hidden">
      <div class="modal-box">
        <h2>Edit entry</h2>
        <form id="edit-form">
          <label>
            What did you do?
            <input id="edit-activity" name="activity" type="text" required />
          </label>
          <div class="time-range">
            <label>
              From
              <input id="edit-start-time" name="start_time" type="time" required />
            </label>
            <span class="time-sep">→</span>
            <label>
              To
              <input id="edit-end-time" name="end_time" type="time" required />
            </label>
          </div>
          <div class="modal-actions">
            <button id="edit-cancel" class="modal-btn" type="button">Cancel</button>
            <button class="modal-btn primary" type="submit">Save</button>
          </div>
        </form>
      </div>
    </div>

    <div id="confirm-modal" class="modal-backdrop hidden">
      <div class="modal-box">
        <p>Delete this entry?</p>
        <div class="modal-actions">
          <button id="confirm-cancel" class="modal-btn" type="button">Cancel</button>
          <button id="confirm-delete" class="modal-btn danger" type="button">Delete</button>
        </div>
      </div>
    </div>

    <div id="toast" aria-live="polite"></div>
    <script src="/time-log.js" defer></script>
  </body>
</html>
